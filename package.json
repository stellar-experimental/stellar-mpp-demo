{
  "name": "stellar-mpp-demo",
  "private": true,
  "scripts": {
    "build:stellar-mpp-sdk": "pnpm --filter stellar-mpp-sdk run build",
    "dev": "concurrently -n mpp-server,ai-worker,frontend -c blue,magenta,green \"pnpm dev:mpp-server\" \"pnpm dev:ai-worker\" \"pnpm dev:frontend\"",
    "dev:frontend": "pnpm --filter frontend run dev",
    "dev:mpp-server": "pnpm --filter mpp-server run dev",
    "dev:ai-worker": "pnpm --filter ai-worker run dev",
    "build": "pnpm --filter './packages/*' run build",
    "deploy:all": "pnpm --filter ai-worker run deploy && pnpm --filter mpp-server run deploy && pnpm --filter frontend run deploy",
    "lint": "oxlint packages/ai-worker packages/mpp-server packages/frontend",
    "lint:fix": "oxlint --fix packages/ai-worker packages/mpp-server packages/frontend",
    "format": "oxfmt --write packages/ai-worker packages/mpp-server packages/frontend",
    "format:check": "oxfmt --check packages/ai-worker packages/mpp-server packages/frontend",
    "typecheck": "pnpm -r --parallel run check:types",
    "test:unit": "pnpm -r --parallel run test",
    "test:smoke:remote": "bun run test/e2e-protocol-smoke.ts --target remote",
    "test:smoke:local": "bun run test/e2e-protocol-smoke.ts --target local",
    "test:smoke:browser:remote": "bash test/e2e-browser-smoke.sh",
    "test:smoke:browser:local": "bash test/e2e-browser-smoke.sh http://localhost:3000",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test:unit"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0"
  }
}
