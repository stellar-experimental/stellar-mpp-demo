{
  "name": "stellar-mpp-demo",
  "private": true,
  "scripts": {
    "build:sdk": "pnpm --filter stellar-mpp-sdk run build",
    "dev": "concurrently -n server,ai,frontend -c blue,magenta,green \"pnpm dev:server\" \"pnpm dev:ai\" \"pnpm dev:frontend\"",
    "dev:frontend": "pnpm --filter frontend run dev",
    "dev:server": "pnpm --filter mpp-server run dev",
    "dev:ai": "pnpm --filter ai-worker run dev",
    "build": "pnpm --filter './packages/*' run build",
    "deploy": "pnpm --filter ai-worker run deploy && pnpm --filter mpp-server run deploy && pnpm --filter frontend run deploy",
    "lint": "oxlint packages/ai-worker packages/mpp-server packages/frontend",
    "lint:fix": "oxlint --fix packages/ai-worker packages/mpp-server packages/frontend",
    "format": "oxfmt --write packages/ai-worker packages/mpp-server packages/frontend",
    "format:check": "oxfmt --check packages/ai-worker packages/mpp-server packages/frontend",
    "typecheck": "pnpm -r --parallel run check:types",
    "test": "pnpm -r --parallel run test",
    "test:e2e": "bash test/e2e-smoke.sh",
    "test:e2e:local": "bash test/e2e-smoke.sh http://localhost:3000",
    "test:e2e:channel-lifecycle:local": "bash test/e2e-channel-lifecycle-local.sh",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0"
  }
}
