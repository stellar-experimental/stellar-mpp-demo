{
  "name": "mpp-channel-demo",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,ai,frontend -c blue,magenta,green \"pnpm dev:server\" \"pnpm dev:ai\" \"pnpm dev:frontend\"",
    "dev:frontend": "pnpm --filter frontend run dev",
    "dev:server": "pnpm --filter mpp-server run dev",
    "dev:ai": "pnpm --filter ai-worker run dev",
    "build": "pnpm --filter './packages/*' run build",
    "deploy": "pnpm --filter ai-worker deploy && pnpm --filter mpp-server deploy && pnpm --filter frontend deploy",
    "test:e2e": "bash test/e2e-smoke.sh",
    "test:e2e:local": "bash test/e2e-smoke.sh http://localhost:3000"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}